{
  "name": "n8n-mcp-connector",
  "version": "2.0.0",
  "description": "Advanced workflow automation connector for n8n platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "tsx src/tests/run-tests.ts",
    "test:suite": "tsx src/tests/test-suite.ts",
    "test:watch": "tsx watch src/tests/run-tests.ts",
    "test:build": "npm run build && node dist/tests/run-tests.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "validate": "npm run lint && npm run test && npm run build"
  },
  "bin": {
    "n8n-mcp-connector": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "mcp.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0",
    "dotenv": "^17.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "workflow",
    "automation",
    "n8n",
    "mcp",
    "claude",
    "connector"
  ],
  "author": "Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosjperez/n8n-mcp-connector.git"
  },
  "bugs": {
    "url": "https://github.com/carlosjperez/n8n-mcp-connector/issues"
  },
  "homepage": "https://github.com/carlosjperez/n8n-mcp-connector#readme"
}
