# N8N MCP Connector Configuration
# Copy this file to .env and configure your values

# =============================================================================
# N8N Configuration
# =============================================================================

# N8N instance base URL (required)
N8N_BASE_URL=http://localhost:5678

# N8N API key for authentication (required)
# Get this from your N8N instance: Settings > API Keys
N8N_API_KEY=your_api_key_here

# Request timeout in milliseconds (default: 30000)
N8N_TIMEOUT=30000

# Number of retry attempts for failed requests (default: 3)
N8N_RETRIES=3

# Delay between retry attempts in milliseconds (default: 1000)
N8N_RETRY_DELAY=1000

# =============================================================================
# Server Configuration
# =============================================================================

# Server port (default: 3000)
SERVER_PORT=3000

# Server host (default: localhost)
SERVER_HOST=localhost

# Environment: development, production, test (default: development)
NODE_ENV=development

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# =============================================================================
# Cache Configuration
# =============================================================================

# Default cache TTL in milliseconds (default: 600000 = 10 minutes)
CACHE_DEFAULT_TTL=600000

# Maximum number of cache entries (default: 1000)
CACHE_MAX_SIZE=1000

# Cache cleanup check period in milliseconds (default: 60000 = 1 minute)
CACHE_CHECK_PERIOD=60000

# Workflow list cache TTL in milliseconds (default: 300000 = 5 minutes)
CACHE_WORKFLOWS_LIST_TTL=300000

# Workflow details cache TTL in milliseconds (default: 600000 = 10 minutes)
CACHE_WORKFLOWS_DETAILS_TTL=600000

# Completed execution cache TTL in milliseconds (default: 1800000 = 30 minutes)
CACHE_EXECUTIONS_COMPLETED_TTL=1800000

# Running execution cache TTL in milliseconds (default: 30000 = 30 seconds)
CACHE_EXECUTIONS_RUNNING_TTL=30000

# Node cache TTL in milliseconds (default: 900000 = 15 minutes)
CACHE_NODES_TTL=900000

# =============================================================================
# Performance Configuration
# =============================================================================

# HTTP connection pool size (default: 10)
CONNECTION_POOL_SIZE=10

# Request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT=30000

# Circuit breaker failure threshold (default: 5)
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker timeout in milliseconds (default: 60000 = 1 minute)
CIRCUIT_BREAKER_TIMEOUT=60000

# Rate limit: requests per window (default: 100)
RATE_LIMIT_REQUESTS=100

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW=60000

# =============================================================================
# Monitoring Configuration
# =============================================================================

# Enable monitoring and metrics collection (default: true)
MONITORING_ENABLED=true

# Metrics collection interval in milliseconds (default: 30000 = 30 seconds)
METRICS_INTERVAL=30000

# Health check interval in milliseconds (default: 60000 = 1 minute)
HEALTH_CHECK_INTERVAL=60000

# Performance threshold in milliseconds (default: 5000 = 5 seconds)
PERFORMANCE_THRESHOLD=5000

# =============================================================================
# Development Configuration
# =============================================================================

# Enable debug mode for development
DEBUG=n8n-mcp:*

# Enable verbose logging in development
VERBOSE=false

# =============================================================================
# Production Configuration
# =============================================================================

# For production, consider these optimizations:
# - Increase cache TTL values for better performance
# - Reduce log level to 'warn' or 'error'
# - Increase connection pool size for high load
# - Enable monitoring for observability
# - Set appropriate rate limits

# Example production values:
# LOG_LEVEL=warn
# CACHE_WORKFLOWS_DETAILS_TTL=1800000
# CONNECTION_POOL_SIZE=20
# MONITORING_ENABLED=true
