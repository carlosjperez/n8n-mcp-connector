{
  "mcpServers": {
    "n8n-workflows": {
      "command": "npx",
      "args": ["n8n-mcp-connector@latest"],
      "env": {
        "N8N_BASE_URL": "https://tu-instancia-n8n.com",
        "N8N_API_KEY": "tu_api_key_aqui",
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "MAX_CONCURRENT_REQUESTS": "10",
        "REQUEST_TIMEOUT": "30000"
      },
      "description": "N8N Workflow Automation - Ejecuta, monitorea y gestiona workflows de n8n desde Cursor",
      "capabilities": [
        "workflow_execution",
        "workflow_management",
        "execution_monitoring",
        "webhook_creation"
      ]
    }
  },
  "settings": {
    "autoRestart": true,
    "healthCheck": {
      "enabled": true,
      "interval": 60000
    },
    "logging": {
      "level": "info",
      "enableConsole": true
    }
  }
}